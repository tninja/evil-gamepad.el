;;; evil-gamepad-test.el --- Tests for evil-gamepad -*- lexical-binding: t; -*-

(require 'ert)
(require 'evil)
(require 'evil-gamepad)

(ert-deftest evil-gamepad-mode-binds-normal-movement-keys ()
  (let ((evil-normal-state-map (make-sparse-keymap))
        (evil-visual-state-map (make-sparse-keymap)))
    (evil-gamepad-mode 1)
    (should (eq (lookup-key evil-normal-state-map (kbd "a"))
                #'evil-backward-char))
    (should (eq (lookup-key evil-normal-state-map (kbd "d"))
                #'evil-forward-char))
    (should (eq (lookup-key evil-normal-state-map (kbd "w"))
                #'evil-previous-line))
    (should (eq (lookup-key evil-normal-state-map (kbd "s"))
                #'evil-next-line))
    (evil-gamepad-mode -1)))

(ert-deftest evil-gamepad-mode-binds-normal-action-keys ()
  (let ((evil-normal-state-map (make-sparse-keymap))
        (evil-visual-state-map (make-sparse-keymap)))
    (evil-gamepad-mode 1)
